    "id": "netstat-port",
    "name": "查询端口占用进程",
    "description": "通过端口号查询占用该端口的进程信息",
    "category": "网络工具",
    "tags": ["网络", "进程", "TCP/UDP"],
    "engine": "cmd",
    "template": "netstat -ano | findstr :{{port}}",
    "params": [
      {
        "key": "port",
        "label": "端口号",
        "type": "number",
        "required": true,
        "defaultValue": 8080,
        "hint": "用于查询指定端口被哪个进程占用",
        "validation": { "kind": "regex", "pattern": "^[0-9]{1,5}$" }
      }
    ],
    "platform": "windows",
    "usage": "用于查询端口占用情况，最后一列为 PID。\n可配合 taskkill /PID <PID> /F 终止进程。"
  },
