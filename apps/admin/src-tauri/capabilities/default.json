{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:tray:default",
    "opener:default",
    "fs:default",
    "fs:allow-write-text-file",
    "fs:allow-applocaldata-read",
    "fs:allow-applocaldata-write",
    "dialog:default",
    "shell:allow-open"
  ]
}
